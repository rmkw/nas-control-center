PORT=8080
HOST=127.0.0.1
NAS_NAME=nas.local
BACKEND_MODE=local
VAULT_USER=usuario
VAULT_PASS=change-this-password
# Recommended for production. If set, VAULT_PASS_SHA256 is used instead of VAULT_PASS.
# Generate it with: printf '%s' 'your-password' | shasum -a 256
VAULT_PASS_SHA256=
SESSION_TTL_HOURS=8
LOGIN_MAX_ATTEMPTS=8
TEXT_LIMIT_BYTES=1048576
STORAGE_ROOTS=public:./data/public,private:./data/private

# SMB mode. Requires smbclient installed on the server running Haze Vault.
# BACKEND_MODE=smb
# SMB_HOST=192.168.0.3
# SMB_WORKGROUP=WORKGROUP
# SMBCLIENT_BIN=smbclient
# SMB_TIMEOUT_MS=30000
